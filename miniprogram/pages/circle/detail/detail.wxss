/* pages/circle/detail/detail.wxss */
.container {
  padding: 24rpx;
  background: #f5f5f5;
  min-height: 100vh;
}

.circle-header {
  background: #fff;
  border-radius: 16rpx;
  padding: 32rpx;
  margin-bottom: 24rpx;
}

.circle-name {
  font-size: 36rpx;
  font-weight: bold;
  margin-bottom: 16rpx;
}

.circle-desc {
  font-size: 28rpx;
  color: #666;
  margin-bottom: 24rpx;
  line-height: 1.5;
}

.circle-meta {
  display: flex;
  align-items: center;
  gap: 16rpx;
  margin-bottom: 32rpx;
}

.tag {
  background: #07C160;
  color: #fff;
  padding: 8rpx 16rpx;
  border-radius: 8rpx;
  font-size: 24rpx;
}

.count {
  font-size: 26rpx;
  color: #999;
}

.circle-actions,
.circle-management {
  display: flex;
  gap: 16rpx;
}

.btn {
  flex: 1;
  height: 80rpx;
  line-height: 80rpx;
  border-radius: 40rpx;
  font-size: 28rpx;
  text-align: center;
}

.btn-primary {
  background: #07C160;
  color: #fff;
}

.btn-secondary {
  background: #f0f0f0;
  color: #333;
}

.btn-outline {
  border: 2rpx solid #07C160;
  color: #07C160;
  background: transparent;
}

.section {
  background: #fff;
  border-radius: 16rpx;
  padding: 24rpx;
  margin-bottom: 24rpx;
}

.section-title {
  font-size: 30rpx;
  font-weight: bold;
  margin-bottom: 24rpx;
}

.trip-item {
  padding: 24rpx;
  border: 2rpx solid #f0f0f0;
  border-radius: 12rpx;
  margin-bottom: 16rpx;
}

.trip-item:last-child {
  margin-bottom: 0;
}

.route {
  display: flex;
  align-items: center;
  gap: 12rpx;
  margin-bottom: 16rpx;
}

.from,
.to {
  font-size: 30rpx;
  font-weight: bold;
}

.arrow {
  color: #07C160;
}

.trip-info,
.trip-meta {
  display: flex;
  justify-content: space-between;
  font-size: 26rpx;
  color: #666;
}

.status {
  color: #07C160;
}

.member-grid {
  display: grid;
  grid-template-columns: repeat(5, 1fr);
  gap: 24rpx;
}

.member-item {
  text-align: center;
  position: relative;
}

.avatar {
  width: 80rpx;
  height: 80rpx;
  border-radius: 50%;
  margin-bottom: 8rpx;
}

.nickname {
  font-size: 22rpx;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.role-tag {
  position: absolute;
  top: -8rpx;
  right: 0;
  background: #ff4d4f;
  color: #fff;
  font-size: 20rpx;
  padding: 4rpx 8rpx;
  border-radius: 8rpx;
}

.role-tag.admin {
  background: #1890ff;
}

.status-dot {
  width: 16rpx;
  height: 16rpx;
  background: #07C160;
  border-radius: 50%;
  position: absolute;
  bottom: 0;
  right: 0;
  border: 2rpx solid #fff;
}

.loading {
  text-align: center;
  padding: 40rpx;
  color: #999;
}
