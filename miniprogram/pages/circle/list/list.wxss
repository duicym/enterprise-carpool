/* pages/circle/list/list.wxss */
.container {
  min-height: 100vh;
  background-color: #f5f5f5;
  padding-bottom: 120rpx;
}

/* 标签页 */
.tabs {
  display: flex;
  background-color: #fff;
  padding: 20rpx 30rpx;
  margin-bottom: 20rpx;
}

.tab {
  flex: 1;
  text-align: center;
  padding: 16rpx 0;
  font-size: 28rpx;
  color: #666;
  border-radius: 8rpx;
  transition: all 0.3s;
}

.tab.active {
  background-color: #07C160;
  color: #fff;
  font-weight: 500;
}

/* 创建按钮 */
.create-btn {
  display: flex;
  align-items: center;
  justify-content: center;
  background-color: #07C160;
  color: #fff;
  margin: 20rpx;
  padding: 24rpx;
  border-radius: 12rpx;
  font-size: 30rpx;
  font-weight: 500;
}

.create-btn text:first-child {
  font-size: 36rpx;
  margin-right: 8rpx;
}

/* 圈子列表 */
.circle-list {
  padding: 0 20rpx;
}

.circle-card {
  background-color: #fff;
  border-radius: 16rpx;
  padding: 24rpx;
  margin-bottom: 20rpx;
}

.circle-header {
  display: flex;
  margin-bottom: 20rpx;
}

.cover {
  width: 120rpx;
  height: 120rpx;
  border-radius: 12rpx;
  margin-right: 20rpx;
  background-color: #f0f0f0;
}

.circle-info {
  flex: 1;
  display: flex;
  flex-direction: column;
  justify-content: center;
}

.circle-name {
  font-size: 32rpx;
  font-weight: bold;
  color: #333;
  margin-bottom: 12rpx;
}

.circle-type {
  font-size: 24rpx;
  color: #999;
  background-color: #f5f5f5;
  padding: 6rpx 16rpx;
  border-radius: 20rpx;
  display: inline-block;
}

.circle-footer {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding-top: 16rpx;
  border-top: 1rpx solid #f0f0f0;
}

.member-count {
  display: flex;
  align-items: baseline;
}

.member-count .count {
  font-size: 36rpx;
  font-weight: bold;
  color: #07C160;
}

.member-count .label {
  font-size: 24rpx;
  color: #999;
  margin-left: 4rpx;
}

.role-badge {
  font-size: 24rpx;
  color: #fff;
  background-color: #07C160;
  padding: 6rpx 16rpx;
  border-radius: 20rpx;
}

.role-badge.admin {
  background-color: #ff9800;
}

/* 空状态 */
.empty-state {
  text-align: center;
  padding: 160rpx 40rpx;
}

.empty-icon {
  font-size: 120rpx;
  display: block;
  margin-bottom: 24rpx;
}

.empty-text {
  font-size: 32rpx;
  color: #333;
  display: block;
  margin-bottom: 12rpx;
}

.empty-desc {
  font-size: 26rpx;
  color: #999;
}

.loading {
  text-align: center;
  padding: 40rpx;
  color: #999;
  font-size: 28rpx;
}
