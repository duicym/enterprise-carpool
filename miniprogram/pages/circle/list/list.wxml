<!--pages/circle/list/list.wxml-->
<view class="container">
  <!-- 顶部标签 -->
  <view class="tabs">
    <view 
      class="tab {{currentTab === 'all' ? 'active' : ''}}"
      bindtap="switchTab"
      data-key="all"
    >
      全部圈子
    </view>
    <view 
      class="tab {{currentTab === 'owner' ? 'active' : ''}}"
      bindtap="switchTab"
      data-key="owner"
    >
      我创建的
    </view>
  </view>

  <!-- 发布按钮 -->
  <view class="create-btn" bindtap="goToCreate">
    <text>+</text>
    <text>创建圈子</text>
  </view>

  <!-- 圈子列表 -->
  <view class="circle-list">
    <block wx:if="{{circles.length > 0}}">
      <view 
        class="circle-card" 
        wx:for="{{circles}}" 
        wx:key="id"
        bindtap="goToDetail"
        data-id="{{item.id}}"
      >
        <view class="circle-header">
          <image class="cover" src="{{item.coverImage || '/images/default-circle.png'}}" mode="aspectFill"></image>
          <view class="circle-info">
            <view class="circle-name">{{item.name}}</view>
            <view class="circle-type">{{formatType(item.type)}}</view>
          </view>
        </view>

        <view class="circle-footer">
          <view class="member-count">
            <text class="count">{{item.memberCount}}</text>
            <text class="label">人</text>
          </view>
          <view class="role-badge" wx:if="{{item.role === 1}}">圈主</view>
          <view class="role-badge admin" wx:elif="{{item.role === 2}}">管理员</view>
        </view>
      </view>
    </block>

    <block wx:else>
      <view class="empty-state">
        <text class="empty-icon">👥</text>
        <text class="empty-text">暂无圈子</text>
        <view class="empty-desc">创建一个属于你的圈子吧</view>
      </view>
    </block>
  </view>

  <!-- 加载中 -->
  <view wx:if="{{loading}}" class="loading">加载中...</view>
</view>
