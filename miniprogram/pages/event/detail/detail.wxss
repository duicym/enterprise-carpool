/* pages/event/detail/detail.wxss */
.container {
  padding: 24rpx;
  background: #f5f5f5;
  min-height: 100vh;
}

.event-card {
  background: #fff;
  border-radius: 16rpx;
  overflow: hidden;
  margin-bottom: 24rpx;
}

.event-header {
  padding: 32rpx;
  background: linear-gradient(135deg, #1890ff 0%, #1678dc 100%);
  color: #fff;
}

.event-title {
  font-size: 36rpx;
  font-weight: bold;
  margin-bottom: 16rpx;
}

.event-location {
  font-size: 28rpx;
  opacity: 0.9;
}

.time-section {
  padding: 24rpx;
  border-bottom: 2rpx solid #f0f0f0;
}

.time-item {
  display: flex;
  justify-content: space-between;
  padding: 12rpx 0;
  font-size: 28rpx;
}

.time-label {
  color: #666;
}

.time-value {
  color: #333;
  font-weight: bold;
}

.description-section {
  padding: 24rpx;
  border-bottom: 2rpx solid #f0f0f0;
}

.section-title {
  font-size: 30rpx;
  font-weight: bold;
  margin-bottom: 16rpx;
}

.description {
  font-size: 28rpx;
  color: #666;
  line-height: 1.6;
  white-space: pre-line;
}

.stats-section {
  display: flex;
  padding: 24rpx;
  border-bottom: 2rpx solid #f0f0f0;
}

.stat-item {
  flex: 1;
  text-align: center;
}

.stat-number {
  display: block;
  font-size: 40rpx;
  font-weight: bold;
  color: #1890ff;
  margin-bottom: 8rpx;
}

.stat-label {
  font-size: 24rpx;
  color: #999;
}

.allocation-section {
  padding: 24rpx;
  text-align: center;
  border-bottom: 2rpx solid #f0f0f0;
}

.allocation-status {
  display: flex;
  align-items: center;
  justify-content: center;
  gap: 12rpx;
  margin-bottom: 16rpx;
  color: #07C160;
  font-size: 30rpx;
  font-weight: bold;
}

.status-icon {
  font-size: 36rpx;
}

.btn-view-allocation {
  display: inline-block;
  padding: 16rpx 48rpx;
  background: #1890ff;
  color: #fff;
  border-radius: 32rpx;
  font-size: 28rpx;
}

.participants-section {
  padding: 24rpx;
  border-bottom: 2rpx solid #f0f0f0;
}

.participant-list {
  max-height: 400rpx;
  overflow-y: auto;
}

.participant-item {
  display: flex;
  align-items: center;
  padding: 16rpx 0;
  border-bottom: 2rpx solid #f0f0f0;
}

.participant-item:last-child {
  border-bottom: none;
}

.participant-item .avatar {
  width: 64rpx;
  height: 64rpx;
  border-radius: 50%;
  margin-right: 16rpx;
}

.participant-info {
  flex: 1;
  display: flex;
  align-items: center;
  gap: 12rpx;
}

.name {
  font-size: 28rpx;
  font-weight: bold;
}

.type-tag {
  padding: 4rpx 12rpx;
  background: #1890ff;
  color: #fff;
  border-radius: 8rpx;
  font-size: 24rpx;
}

.type-tag.passenger {
  background: #ff9b2d;
}

.seats {
  font-size: 26rpx;
  color: #07C160;
  font-weight: bold;
}

.action-section {
  padding: 24rpx;
}

.btn-join,
.btn-leave,
.btn-allocate {
  width: 100%;
  height: 88rpx;
  border-radius: 44rpx;
  font-size: 32rpx;
  font-weight: bold;
}

.btn-join {
  background: linear-gradient(135deg, #1890ff 0%, #1678dc 100%);
  color: #fff;
}

.btn-leave {
  background: #f5f5f5;
  color: #666;
}

.btn-allocate {
  background: linear-gradient(135deg, #07C160 0%, #05a850 100%);
  color: #fff;
}

.modal {
  position: fixed;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  background: rgba(0, 0, 0, 0.5);
  display: flex;
  align-items: center;
  justify-content: center;
  z-index: 1000;
}

.modal-content {
  background: #fff;
  border-radius: 16rpx;
  padding: 32rpx;
  width: 90%;
  max-height: 80vh;
  overflow-y: auto;
}

.modal-title {
  font-size: 32rpx;
  font-weight: bold;
  text-align: center;
  margin-bottom: 24rpx;
}

.allocation-list {
  max-height: 600rpx;
  overflow-y: auto;
}

.allocation-group {
  margin-bottom: 24rpx;
  padding: 16rpx;
  background: #f9f9f9;
  border-radius: 12rpx;
}

.group-header {
  display: flex;
  justify-content: space-between;
  margin-bottom: 16rpx;
  font-weight: bold;
}

.driver-name {
  font-size: 28rpx;
  color: #333;
}

.seats-count {
  font-size: 26rpx;
  color: #07C160;
}

.passenger-list {
  padding-left: 16rpx;
}

.passenger-item {
  display: flex;
  justify-content: space-between;
  padding: 8rpx 0;
  font-size: 26rpx;
  color: #666;
}

.btn-close {
  width: 100%;
  height: 80rpx;
  background: #1890ff;
  color: #fff;
  border-radius: 40rpx;
  font-size: 28rpx;
  margin-top: 24rpx;
}
