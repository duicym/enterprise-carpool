.login-page {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  min-height: 100vh;
  background: linear-gradient(180deg, #e8f5e9, #fff);
  padding: 0 48rpx;
}

/* Logo 区域 */
.logo-section {
  display: flex;
  flex-direction: column;
  align-items: center;
  margin-bottom: 100rpx;
}

.logo-icon {
  font-size: 120rpx;
  margin-bottom: 24rpx;
}

.app-name {
  font-size: 48rpx;
  font-weight: 700;
  color: #333;
  margin-bottom: 16rpx;
}

.app-desc {
  font-size: 28rpx;
  color: #666;
}

/* 登录按钮区域 */
.login-section {
  width: 100%;
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 24rpx;
}

.login-btn {
  width: 100%;
  height: 96rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  border-radius: 48rpx;
  font-size: 32rpx;
  font-weight: 500;
}

.wx-login-btn {
  background: #07c160;
  color: #fff;
}

.btn-icon {
  margin-right: 12rpx;
  font-size: 36rpx;
}

.normal-login-btn {
  background: #fff;
  color: #333;
  border: 2rpx solid #ddd;
}

.skip-btn {
  margin-top: 32rpx;
  padding: 16rpx 32rpx;
}

.skip-btn text {
  font-size: 26rpx;
  color: #999;
}

/* 用户信息展示 */
.user-info-section {
  margin-top: 60rpx;
  display: flex;
  flex-direction: column;
  align-items: center;
}

.user-avatar {
  width: 120rpx;
  height: 120rpx;
  border-radius: 50%;
  margin-bottom: 16rpx;
}

.user-name {
  font-size: 32rpx;
  color: #333;
  font-weight: 500;
}

/* 底部说明 */
.footer-section {
  position: absolute;
  bottom: 60rpx;
  left: 0;
  right: 0;
  text-align: center;
}

.footer-text {
  font-size: 24rpx;
  color: #999;
}
