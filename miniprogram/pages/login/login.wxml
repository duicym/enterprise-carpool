<!--pages/login/login.wxml-->
<view class="login-container">
  <view class="logo-section">
    <view class="logo-icon">🚗</view>
    <view class="app-name">蹭蹭车</view>
    <view class="slogan">让每一次出行都更温暖</view>
  </view>

  <view class="features">
    <view class="feature-item">
      <text class="feature-icon">🤝</text>
      <text class="feature-text">熟人圈子，安全可信</text>
    </view>
    <view class="feature-item">
      <text class="feature-icon">💰</text>
      <text class="feature-text">免费/AA/付费灵活选择</text>
    </view>
    <view class="feature-item">
      <text class="feature-icon">🧠</text>
      <text class="feature-text">团建智能分配车辆</text>
    </view>
  </view>

  <view class="login-section">
    <button 
      class="login-btn" 
      type="primary" 
      open-type="getUserInfo"
      bindgetuserinfo="onGetUserInfo"
      disabled="{{loading}}"
    >
      {{loading ? '登录中...' : '微信一键登录'}}
    </button>
    
    <view class="agreement">
      登录即表示同意
      <text class="link">《用户协议》</text>
      和
      <text class="link">《隐私政策》</text>
    </view>
  </view>
</view>
