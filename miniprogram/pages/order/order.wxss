.order-page {
  display: flex;
  flex-direction: column;
  height: 100vh;
  background: #f5f5f5;
}

/* Tab 栏 */
.tab-bar {
  display: flex;
  white-space: nowrap;
  background: #fff;
  border-bottom: 1rpx solid #eee;
}

.tab-item {
  display: inline-flex;
  flex-direction: column;
  align-items: center;
  padding: 24rpx 32rpx;
  font-size: 28rpx;
  color: #666;
  position: relative;
}

.tab-item.active {
  color: #07c160;
  font-weight: 500;
}

.tab-indicator {
  width: 40rpx;
  height: 4rpx;
  background: #07c160;
  border-radius: 2rpx;
  margin-top: 8rpx;
}

/* 订单列表 */
.order-list {
  flex: 1;
  padding: 16rpx 24rpx;
  overflow-y: auto;
}

.loading-wrap {
  display: flex;
  align-items: center;
  justify-content: center;
  height: 400rpx;
  font-size: 28rpx;
  color: #999;
}

.empty-state {
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 100rpx 0;
}

.empty-icon {
  font-size: 100rpx;
  margin-bottom: 24rpx;
}

.empty-text {
  font-size: 32rpx;
  color: #333;
  font-weight: 500;
  margin-bottom: 12rpx;
}

.empty-desc {
  font-size: 26rpx;
  color: #999;
}

/* 订单卡片 */
.order-card {
  background: #fff;
  border-radius: 16rpx;
  padding: 24rpx;
  margin-bottom: 16rpx;
}

.order-header {
  display: flex;
  align-items: center;
  justify-content: space-between;
  margin-bottom: 20rpx;
  padding-bottom: 16rpx;
  border-bottom: 1rpx solid #f0f0f0;
}

.order-no {
  font-size: 24rpx;
  color: #999;
}

.order-status {
  font-size: 26rpx;
  font-weight: 500;
}

.status-pending { color: #ff9800; }
.status-confirmed { color: #2196f3; }
.status-completed { color: #07c160; }
.status-cancelled { color: #999; }
.status-rejected { color: #f44336; }
.status-no-show { color: #9e9e9e; }

.order-route {
  margin-bottom: 20rpx;
}

.route-point {
  display: flex;
  align-items: center;
  padding: 8rpx 0;
}

.point-dot {
  width: 16rpx;
  height: 16rpx;
  border-radius: 50%;
  margin-right: 16rpx;
  flex-shrink: 0;
}

.point-dot.start { background: #07c160; }
.point-dot.end { background: #f44336; }

.point-text {
  font-size: 28rpx;
  color: #333;
}

.order-footer {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding-bottom: 16rpx;
}

.info-text {
  font-size: 26rpx;
  color: #666;
}

.price-text {
  font-size: 32rpx;
  color: #f44336;
  font-weight: 600;
}

/* 操作按钮 */
.order-actions {
  display: flex;
  justify-content: flex-end;
  padding-top: 16rpx;
  border-top: 1rpx solid #f0f0f0;
}

.action-group {
  display: flex;
  gap: 16rpx;
}

.action-btn {
  padding: 12rpx 32rpx;
  border-radius: 32rpx;
  font-size: 26rpx;
  border: 1rpx solid #ddd;
  color: #666;
  background: #fff;
}

.action-btn.primary {
  background: #07c160;
  color: #fff;
  border-color: #07c160;
}

.action-btn.cancel {
  color: #f44336;
  border-color: #f44336;
}
