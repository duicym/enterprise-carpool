/* pages/trip/detail/detail.wxss */
.container {
  padding: 24rpx;
  background: #f5f5f5;
  min-height: 100vh;
}

.trip-card {
  background: #fff;
  border-radius: 16rpx;
  overflow: hidden;
  margin-bottom: 24rpx;
}

.route-section {
  padding: 32rpx;
  background: linear-gradient(135deg, #07C160 0%, #05a850 100%);
  color: #fff;
}

.route-item {
  display: flex;
  align-items: flex-start;
  gap: 24rpx;
}

.time-point {
  width: 24rpx;
  height: 24rpx;
  border-radius: 50%;
  border: 4rpx solid #fff;
  flex-shrink: 0;
}

.time-point.start {
  background: #fff;
}

.time-point.end {
  background: transparent;
}

.route-line {
  width: 4rpx;
  height: 48rpx;
  background: rgba(255, 255, 255, 0.5);
  margin: 8rpx 0 8rpx 12rpx;
}

.route-detail {
  flex: 1;
}

.label {
  font-size: 24rpx;
  opacity: 0.8;
  margin-bottom: 8rpx;
}

.address {
  font-size: 30rpx;
  font-weight: bold;
  margin-bottom: 8rpx;
}

.time,
.time-tip {
  font-size: 26rpx;
  opacity: 0.8;
}

.driver-section {
  display: flex;
  align-items: center;
  padding: 24rpx;
  border-bottom: 2rpx solid #f0f0f0;
}

.driver-avatar {
  width: 80rpx;
  height: 80rpx;
  border-radius: 50%;
  margin-right: 24rpx;
}

.driver-name {
  font-size: 30rpx;
  font-weight: bold;
  margin-bottom: 8rpx;
}

.driver-rating {
  font-size: 26rpx;
  color: #999;
}

.trip-info-section {
  padding: 24rpx;
}

.info-row {
  display: flex;
  justify-content: space-between;
  padding: 16rpx 0;
  border-bottom: 2rpx solid #f0f0f0;
}

.info-row:last-child {
  border-bottom: none;
}

.info-row .label {
  color: #666;
  font-size: 28rpx;
}

.info-row .value {
  color: #333;
  font-size: 28rpx;
}

.info-row .value.price {
  color: #ff4d4f;
  font-weight: bold;
  font-size: 32rpx;
}

.info-row .value.status {
  color: #07C160;
}

.info-row .value.status_cancel {
  color: #999;
}

.action-section {
  padding: 24rpx;
}

.btn-book {
  width: 100%;
  height: 88rpx;
  background: #07C160;
  color: #fff;
  border-radius: 44rpx;
  font-size: 32rpx;
  font-weight: bold;
}

.btn-book[disabled] {
  background: #ccc;
  color: #999;
}

.driver-actions {
  display: flex;
  gap: 16rpx;
}

.btn-manage,
.btn-cancel {
  flex: 1;
  height: 80rpx;
  border-radius: 40rpx;
  font-size: 28rpx;
}

.btn-manage {
  background: #07C160;
  color: #fff;
}

.btn-cancel {
  background: #f5f5f5;
  color: #666;
}

.bookings-section {
  background: #fff;
  border-radius: 16rpx;
  padding: 24rpx;
}

.section-title {
  font-size: 30rpx;
  font-weight: bold;
  margin-bottom: 24rpx;
}

.booking-item {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 16rpx 0;
  border-bottom: 2rpx solid #f0f0f0;
}

.booking-item:last-child {
  border-bottom: none;
}

.passenger-info {
  display: flex;
  align-items: center;
  gap: 16rpx;
}

.passenger-avatar {
  width: 64rpx;
  height: 64rpx;
  border-radius: 50%;
}

.passenger-detail {
  display: flex;
  flex-direction: column;
  gap: 8rpx;
}

.name {
  font-size: 28rpx;
  font-weight: bold;
}

.phone {
  font-size: 24rpx;
  color: #999;
}

.booking-status {
  display: flex;
  flex-direction: column;
  align-items: flex-end;
  gap: 8rpx;
}

.status,
.status-ok,
.status-cancel,
.status-reject {
  font-size: 24rpx;
  padding: 4rpx 12rpx;
  border-radius: 8rpx;
}

.status {
  background: #ff9b2d;
  color: #fff;
}

.status-ok {
  background: #07C160;
  color: #fff;
}

.status-cancel {
  background: #ccc;
  color: #999;
}

.status-reject {
  background: #ff4d4f;
  color: #fff;
}

.action-buttons {
  display: flex;
  gap: 8rpx;
}

.btn-confirm,
.btn-reject {
  padding: 8rpx 24rpx;
  border-radius: 20rpx;
  font-size: 24rpx;
}

.btn-confirm {
  background: #07C160;
  color: #fff;
}

.btn-reject {
  background: #ff4d4f;
  color: #fff;
}
