/* pages/booking/list/list.wxss */
.container {
  padding: 24rpx;
  background: #f5f5f5;
  min-height: 100vh;
}

.tabs {
  display: flex;
  background: #fff;
  border-radius: 16rpx;
  margin-bottom: 24rpx;
  padding: 8rpx;
}

.tab-item {
  flex: 1;
  text-align: center;
  padding: 16rpx 0;
  font-size: 28rpx;
  color: #666;
  border-radius: 12rpx;
}

.tab-item.active {
  background: #07C160;
  color: #fff;
  font-weight: bold;
}

.booking-list {
  background: #fff;
  border-radius: 16rpx;
  padding: 24rpx;
}

.booking-item {
  padding: 24rpx;
  border: 2rpx solid #f0f0f0;
  border-radius: 12rpx;
  margin-bottom: 16rpx;
}

.booking-item:last-child {
  margin-bottom: 0;
}

.trip-route {
  display: flex;
  align-items: center;
  gap: 12rpx;
  margin-bottom: 16rpx;
  font-size: 30rpx;
  font-weight: bold;
}

.arrow {
  color: #07C160;
}

.booking-info {
  margin-bottom: 16rpx;
}

.row {
  display: flex;
  justify-content: space-between;
  padding: 8rpx 0;
  font-size: 26rpx;
}

.label {
  color: #999;
}

.value {
  color: #333;
}

.value.price {
  color: #ff4d4f;
  font-weight: bold;
}

.booking-footer {
  display: flex;
  justify-content: space-between;
  align-items: center;
}

.passenger .name {
  font-size: 28rpx;
  color: #666;
}

.status-tag {
  padding: 8rpx 16rpx;
  border-radius: 8rpx;
  font-size: 24rpx;
}

.status-tag.status-0 {
  background: #ff9b2d;
  color: #fff;
}

.status-tag.status-1 {
  background: #07C160;
  color: #fff;
}

.status-tag.status-2 {
  background: #1890ff;
  color: #fff;
}

.status-tag.status-3,
.status-tag.status-4,
.status-tag.status-5 {
  background: #ccc;
  color: #999;
}

.booking-actions {
  display: flex;
  gap: 16rpx;
  margin-top: 16rpx;
  padding-top: 16rpx;
  border-top: 2rpx solid #f0f0f0;
}

.btn-action {
  flex: 1;
  height: 64rpx;
  line-height: 64rpx;
  border-radius: 32rpx;
  font-size: 26rpx;
  text-align: center;
}

.btn-cancel {
  background: #f5f5f5;
  color: #666;
}

.btn-review {
  background: #07C160;
  color: #fff;
}

.empty,
.loading {
  text-align: center;
  padding: 80rpx 0;
  color: #999;
  font-size: 28rpx;
}
