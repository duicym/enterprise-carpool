/* pages/booking/detail/detail.wxss */
.container {
  padding: 24rpx;
  background: #f5f5f5;
  min-height: 100vh;
}

.booking-card {
  background: #fff;
  border-radius: 16rpx;
  overflow: hidden;
}

.status-header {
  padding: 32rpx;
  text-align: center;
  color: #fff;
}

.status-header.status-0 {
  background: linear-gradient(135deg, #ff9b2d 0%, #ff8b1a 100%);
}

.status-header.status-1 {
  background: linear-gradient(135deg, #07C160 0%, #05a850 100%);
}

.status-header.status-2 {
  background: linear-gradient(135deg, #1890ff 0%, #1678dc 100%);
}

.status-header.status-3,
.status-header.status-4,
.status-header.status-5 {
  background: linear-gradient(135deg, #ccc 0%, #b8b8b8 100%);
}

.status-text {
  font-size: 36rpx;
  font-weight: bold;
}

.section {
  padding: 24rpx;
  border-bottom: 2rpx solid #f0f0f0;
}

.section:last-child {
  border-bottom: none;
}

.section-title {
  font-size: 30rpx;
  font-weight: bold;
  margin-bottom: 24rpx;
}

.info-row {
  display: flex;
  justify-content: space-between;
  padding: 16rpx 0;
  font-size: 28rpx;
}

.info-row .label {
  color: #666;
}

.info-row .value {
  color: #333;
}

.info-row .value.price {
  color: #ff4d4f;
  font-weight: bold;
  font-size: 32rpx;
}

.passenger-card {
  display: flex;
  align-items: center;
  gap: 24rpx;
}

.passenger-card .avatar {
  width: 80rpx;
  height: 80rpx;
  border-radius: 50%;
}

.passenger-info {
  flex: 1;
  display: flex;
  flex-direction: column;
  gap: 8rpx;
}

.name {
  font-size: 30rpx;
  font-weight: bold;
}

.phone,
.credit {
  font-size: 26rpx;
  color: #999;
}

.contact-btn {
  padding: 12rpx 32rpx;
  background: #07C160;
  color: #fff;
  border-radius: 32rpx;
  font-size: 26rpx;
}

.timeline {
  padding-left: 16rpx;
}

.timeline-item {
  display: flex;
  gap: 24rpx;
  padding: 16rpx 0;
}

.timeline-dot {
  width: 24rpx;
  height: 24rpx;
  border-radius: 50%;
  border: 4rpx solid #ddd;
  flex-shrink: 0;
}

.timeline-dot.active {
  border-color: #07C160;
  background: #07C160;
}

.timeline-content {
  flex: 1;
}

.timeline-title {
  font-size: 28rpx;
  font-weight: bold;
  margin-bottom: 8rpx;
}

.timeline-time {
  font-size: 24rpx;
  color: #999;
}

.timeline-reason {
  font-size: 24rpx;
  color: #ff4d4f;
  margin-top: 8rpx;
}

.review-card {
  background: #f9f9f9;
  padding: 24rpx;
  border-radius: 12rpx;
}

.rating {
  margin-bottom: 16rpx;
  font-size: 40rpx;
  color: #ff9b2d;
}

.content {
  font-size: 28rpx;
  color: #666;
  line-height: 1.6;
}

.action-section {
  padding: 24rpx;
  display: flex;
  gap: 16rpx;
}

.btn-action {
  flex: 1;
  height: 88rpx;
  border-radius: 44rpx;
  font-size: 32rpx;
  font-weight: bold;
}

.btn-cancel {
  background: #f5f5f5;
  color: #666;
}

.btn-complete,
.btn-review {
  background: #07C160;
  color: #fff;
}
