.notification-page {
  display: flex;
  flex-direction: column;
  height: 100vh;
  background: #f5f5f5;
}

/* Tab 栏 */
.tab-bar {
  display: flex;
  align-items: center;
  justify-content: space-between;
  background: #fff;
  padding: 0 24rpx;
  border-bottom: 1rpx solid #eee;
}

.tab-item {
  display: inline-flex;
  flex-direction: column;
  align-items: center;
  padding: 24rpx 24rpx;
  font-size: 28rpx;
  color: #666;
  position: relative;
}

.tab-item.active {
  color: #07c160;
  font-weight: 500;
}

.tab-indicator {
  width: 40rpx;
  height: 4rpx;
  background: #07c160;
  border-radius: 2rpx;
  margin-top: 8rpx;
}

.mark-all-btn {
  padding: 12rpx 20rpx;
  background: #07c160;
  color: #fff;
  font-size: 24rpx;
  border-radius: 16rpx;
}

/* 通知列表 */
.notification-list {
  flex: 1;
  padding: 16rpx 24rpx;
  overflow-y: auto;
}

.loading-wrap {
  display: flex;
  align-items: center;
  justify-content: center;
  height: 400rpx;
  font-size: 28rpx;
  color: #999;
}

.empty-state {
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 100rpx 0;
}

.empty-icon {
  font-size: 100rpx;
  margin-bottom: 24rpx;
}

.empty-text {
  font-size: 32rpx;
  color: #333;
  font-weight: 500;
}

/* 通知卡片 */
.notification-card {
  display: flex;
  align-items: flex-start;
  background: #fff;
  border-radius: 16rpx;
  padding: 24rpx;
  margin-bottom: 16rpx;
}

.notification-card.unread {
  background: #f0f9f4;
}

.notification-icon {
  width: 64rpx;
  height: 64rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  background: #f5f5f5;
  border-radius: 50%;
  margin-right: 20rpx;
  flex-shrink: 0;
}

.icon-text {
  font-size: 32rpx;
}

.notification-content {
  flex: 1;
}

.notification-header {
  display: flex;
  align-items: center;
  justify-content: space-between;
  margin-bottom: 8rpx;
}

.notification-type {
  font-size: 28rpx;
  color: #333;
  font-weight: 500;
}

.notification-time {
  font-size: 24rpx;
  color: #999;
}

.notification-text {
  font-size: 26rpx;
  color: #666;
  line-height: 1.6;
}

.unread-dot {
  width: 16rpx;
  height: 16rpx;
  background: #f44336;
  border-radius: 50%;
  margin-left: 16rpx;
  flex-shrink: 0;
  margin-top: 20rpx;
}
