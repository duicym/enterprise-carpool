.auth-page {
  min-height: 100vh;
  background: #f5f5f5;
  padding: 40rpx 24rpx;
}

/* 页面标题 */
.page-header {
  text-align: center;
  margin-bottom: 48rpx;
}

.page-title {
  font-size: 40rpx;
  font-weight: 700;
  color: #333;
  display: block;
  margin-bottom: 12rpx;
}

.page-desc {
  font-size: 26rpx;
  color: #666;
}

/* 认证状态展示 */
.auth-status-section {
  background: #fff;
  border-radius: 16rpx;
  padding: 60rpx 24rpx;
  display: flex;
  flex-direction: column;
  align-items: center;
  margin-bottom: 32rpx;
}

.status-icon {
  width: 100rpx;
  height: 100rpx;
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 60rpx;
  margin-bottom: 24rpx;
}

.status-icon.success {
  background: #e8f5e9;
  color: #07c160;
}

.status-icon.pending {
  background: #fff3e0;
  color: #ff9800;
}

.status-icon.reject {
  background: #ffebee;
  color: #f44336;
}

.status-text {
  font-size: 36rpx;
  font-weight: 600;
  color: #333;
  margin-bottom: 12rpx;
}

.status-company,
.status-desc,
.status-reason {
  font-size: 28rpx;
  color: #666;
  text-align: center;
  margin-bottom: 32rpx;
}

.status-reason {
  color: #f44336;
}

.status-btn {
  padding: 20rpx 64rpx;
  background: #f5f5f5;
  border-radius: 48rpx;
  font-size: 28rpx;
  color: #333;
}

.status-btn.primary {
  background: #07c160;
  color: #fff;
}

/* 表单 */
.auth-form {
  background: #fff;
  border-radius: 16rpx;
  padding: 24rpx;
}

.form-item {
  margin-bottom: 32rpx;
}

.form-label {
  font-size: 28rpx;
  color: #333;
  font-weight: 500;
  display: block;
  margin-bottom: 12rpx;
}

.required {
  color: #f44336;
}

.form-input {
  height: 80rpx;
  padding: 0 20rpx;
  background: #f5f5f5;
  border-radius: 8rpx;
  font-size: 28rpx;
}

/* 公司搜索列表 */
.company-list {
  background: #fff;
  border: 1rpx solid #eee;
  border-radius: 8rpx;
  margin-top: 12rpx;
  max-height: 400rpx;
  overflow-y: auto;
}

.company-item {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 20rpx;
  border-bottom: 1rpx solid #f0f0f0;
}

.company-item:last-child {
  border-bottom: none;
}

.company-name {
  font-size: 28rpx;
  color: #333;
}

.company-count {
  font-size: 24rpx;
  color: #999;
}

/* 上传区域 */
.upload-area {
  width: 100%;
  min-height: 300rpx;
  background: #f5f5f5;
  border-radius: 8rpx;
  overflow: hidden;
}

.upload-preview {
  width: 100%;
  height: 300rpx;
}

.upload-placeholder {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  padding: 40rpx 0;
}

.upload-icon {
  font-size: 60rpx;
  margin-bottom: 16rpx;
}

.upload-text {
  font-size: 28rpx;
  color: #333;
  margin-bottom: 8rpx;
}

.upload-hint {
  font-size: 24rpx;
  color: #999;
}

/* 提交按钮 */
.submit-btn {
  width: 100%;
  height: 96rpx;
  background: #07c160;
  color: #fff;
  font-size: 32rpx;
  font-weight: 500;
  border-radius: 48rpx;
  margin-top: 48rpx;
  margin-bottom: 32rpx;
}

/* 认证说明 */
.auth-tips {
  background: #fff9e6;
  border-radius: 8rpx;
  padding: 24rpx;
}

.tips-title {
  font-size: 28rpx;
  color: #333;
  font-weight: 500;
  display: block;
  margin-bottom: 12rpx;
}

.tips-item {
  font-size: 24rpx;
  color: #666;
  display: block;
  line-height: 1.8;
}
