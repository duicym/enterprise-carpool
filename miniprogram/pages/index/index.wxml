<!--pages/index/index.wxml-->
<view class="container">
  <!-- 顶部导航 -->
  <view class="header">
    <view class="title">蹭蹭车</view>
    <view class="publish-btn" bindtap="goToPublish">
      <text class="icon">+</text>
      <text>发布行程</text>
    </view>
  </view>

  <!-- 行程列表 -->
  <view class="trip-list">
    <block wx:if="{{trips.length > 0}}">
      <view 
        class="trip-card" 
        wx:for="{{trips}}" 
        wx:key="id"
        bindtap="goToDetail"
        data-id="{{item.id}}"
      >
        <view class="trip-header">
          <view class="driver-info">
            <image class="avatar" src="{{item.driver.avatarUrl}}" mode="aspectFill"></image>
            <view class="driver-name">{{item.driver.nickname}}</view>
          </view>
          <view class="trip-status status-{{item.status}}">
            {{item.status === 1 ? '招募中' : item.status === 2 ? '已满员' : '进行中'}}
          </view>
        </view>

        <view class="trip-route">
          <view class="route-item">
            <view class="dot start"></view>
            <view class="address">{{item.startAddress}}</view>
          </view>
          <view class="line"></view>
          <view class="route-item">
            <view class="dot end"></view>
            <view class="address">{{item.endAddress}}</view>
          </view>
        </view>

        <view class="trip-footer">
          <view class="trip-info">
            <text class="time">{{formatDate(item.departureTime)}}</text>
            <text class="seats">剩余 {{item.availableSeats}}/{{item.seatCount}} 座</text>
          </view>
          <view class="trip-fee">
            {{formatFee(item.feeMode, item.feeAmount)}}
          </view>
        </view>
      </view>
    </block>

    <block wx:else>
      <view class="empty-state">
        <text class="empty-icon">🚗</text>
        <text class="empty-text">暂无行程</text>
      </view>
    </block>
  </view>

  <!-- 加载中 -->
  <view wx:if="{{loading}}" class="loading">
    <text>加载中...</text>
  </view>
</view>
