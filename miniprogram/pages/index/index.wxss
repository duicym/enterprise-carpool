/* pages/index/index.wxss */
.container {
  min-height: 100vh;
  background-color: #f5f5f5;
  padding-bottom: 120rpx;
}

.header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 30rpx;
  background-color: #fff;
  margin-bottom: 20rpx;
}

.title {
  font-size: 40rpx;
  font-weight: bold;
  color: #333;
}

.publish-btn {
  display: flex;
  align-items: center;
  background-color: #07C160;
  color: #fff;
  padding: 16rpx 32rpx;
  border-radius: 40rpx;
  font-size: 28rpx;
}

.publish-btn .icon {
  font-size: 36rpx;
  margin-right: 8rpx;
}

/* 行程列表 */
.trip-list {
  padding: 0 20rpx;
}

.trip-card {
  background-color: #fff;
  border-radius: 16rpx;
  padding: 24rpx;
  margin-bottom: 20rpx;
}

.trip-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 24rpx;
}

.driver-info {
  display: flex;
  align-items: center;
}

.avatar {
  width: 72rpx;
  height: 72rpx;
  border-radius: 50%;
  margin-right: 16rpx;
}

.driver-name {
  font-size: 28rpx;
  color: #333;
}

.trip-status {
  font-size: 24rpx;
  padding: 8rpx 16rpx;
  border-radius: 20rpx;
}

.status-1 {
  background-color: #e8f5e9;
  color: #07C160;
}

.status-2 {
  background-color: #ffebee;
  color: #f44336;
}

/* 路线 */
.trip-route {
  margin: 24rpx 0;
}

.route-item {
  display: flex;
  align-items: center;
  margin-bottom: 16rpx;
}

.dot {
  width: 16rpx;
  height: 16rpx;
  border-radius: 50%;
  margin-right: 16rpx;
  flex-shrink: 0;
}

.dot.start {
  background-color: #07C160;
}

.dot.end {
  background-color: #f44336;
}

.address {
  font-size: 28rpx;
  color: #333;
  flex: 1;
}

.line {
  width: 4rpx;
  height: 32rpx;
  background-color: #e0e0e0;
  margin-left: 8rpx;
}

/* 底部信息 */
.trip-footer {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding-top: 16rpx;
  border-top: 1rpx solid #f0f0f0;
}

.trip-info {
  display: flex;
  flex-direction: column;
  gap: 8rpx;
}

.trip-info .time {
  font-size: 26rpx;
  color: #999;
}

.trip-info .seats {
  font-size: 24rpx;
  color: #07C160;
  font-weight: 500;
}

.trip-fee {
  font-size: 32rpx;
  color: #f44336;
  font-weight: bold;
}

/* 空状态 */
.empty-state {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  padding: 120rpx 0;
}

.empty-icon {
  font-size: 120rpx;
  margin-bottom: 24rpx;
}

.empty-text {
  font-size: 28rpx;
  color: #999;
}

/* 加载中 */
.loading {
  text-align: center;
  padding: 40rpx;
  color: #999;
  font-size: 28rpx;
}
