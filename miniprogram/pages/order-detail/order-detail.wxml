<view class="detail-page">
  <view wx:if="{{loading}}" class="loading-wrap">
    <text>加载中...</text>
  </view>

  <view wx:else class="detail-content">
    <!-- 状态卡片 -->
    <view class="status-card">
      <text class="status-icon">{{order.status === 0 ? '⏳' : order.status === 1 ? '✓' : order.status === 2 ? '🎉' : order.status === 3 ? '✗' : '!'}}</text>
      <text class="status-text {{statusClassMap[order.status]}}">{{statusMap[order.status]}}</text>
    </view>

    <!-- 路线信息 -->
    <view class="route-card">
      <view class="route-point">
        <view class="point-dot start"></view>
        <view class="point-info">
          <text class="point-label">上车点</text>
          <text class="point-address">{{order.pickup_address}}</text>
        </view>
      </view>
      <view class="route-line"></view>
      <view class="route-point">
        <view class="point-dot end"></view>
        <view class="point-info">
          <text class="point-label">目的地</text>
          <text class="point-address">{{order.dropoff_address}}</text>
        </view>
      </view>
    </view>

    <!-- 订单信息 -->
    <view class="info-card">
      <view class="info-title">订单信息</view>
      <view class="info-row">
        <text class="info-label">订单号</text>
        <text class="info-value">{{order.order_no}}</text>
      </view>
      <view class="info-row">
        <text class="info-label">出发时间</text>
        <text class="info-value">{{order.departure_time}}</text>
      </view>
      <view class="info-row">
        <text class="info-label">座位数</text>
        <text class="info-value">{{order.seats_booked}}</text>
      </view>
      <view class="info-row">
        <text class="info-label">金额</text>
        <text class="info-value price">¥{{order.total_amount || 0}}</text>
      </view>
      <view class="info-row" wx:if="{{order.passenger_cancel_reason}}">
        <text class="info-label">乘客取消原因</text>
        <text class="info-value">{{order.passenger_cancel_reason}}</text>
      </view>
      <view class="info-row" wx:if="{{order.driver_cancel_reason}}">
        <text class="info-label">车主取消原因</text>
        <text class="info-value">{{order.driver_cancel_reason}}</text>
      </view>
    </view>

    <!-- 对方信息 -->
    <view class="info-card">
      <view class="info-title">{{isDriver ? '乘客信息' : '车主信息'}}</view>
      <view class="user-info">
        <image class="user-avatar" src="{{(isDriver ? order.passenger : order.driver)?.avatar_url || '/images/default-avatar.png'}}" mode="aspectFill" />
        <view class="user-detail">
          <text class="user-name">{{(isDriver ? order.passenger : order.driver)?.nickname || '未知'}}</text>
          <text class="user-phone" bindtap="contactOther">📞 联系{{isDriver ? '乘客' : '车主'}}</text>
        </view>
      </view>
    </view>

    <!-- 操作按钮 -->
    <view class="action-bar">
      <view wx:if="{{order.status === 0 || order.status === 1}}" class="action-group">
        <view class="action-btn cancel" bindtap="cancelOrder">取消订单</view>
        <view class="action-btn primary" bindtap="confirmOrder" wx:if="{{order.status === 0 && isDriver}}">确认接单</view>
        <view class="action-btn primary" bindtap="completeOrder" wx:if="{{order.status === 1}}">完成行程</view>
      </view>
      <view wx:if="{{order.status === 2}}" class="action-group">
        <view class="action-btn primary full-width" bindtap="writeReview">评价对方</view>
      </view>
    </view>
  </view>
</view>
