.detail-page {
  min-height: 100vh;
  background: #f5f5f5;
  padding: 24rpx;
  padding-bottom: 160rpx;
}

.loading-wrap {
  display: flex;
  align-items: center;
  justify-content: center;
  height: 60vh;
  font-size: 28rpx;
  color: #999;
}

.detail-content {
  display: flex;
  flex-direction: column;
  gap: 24rpx;
}

/* 状态卡片 */
.status-card {
  background: #fff;
  border-radius: 16rpx;
  padding: 40rpx;
  display: flex;
  flex-direction: column;
  align-items: center;
}

.status-icon {
  font-size: 80rpx;
  margin-bottom: 16rpx;
}

.status-text {
  font-size: 32rpx;
  font-weight: 600;
}

.status-pending { color: #ff9800; }
.status-confirmed { color: #2196f3; }
.status-completed { color: #07c160; }
.status-cancelled { color: #999; }
.status-rejected { color: #f44336; }
.status-no-show { color: #9e9e9e; }

/* 路线卡片 */
.route-card {
  background: #fff;
  border-radius: 16rpx;
  padding: 32rpx;
}

.route-point {
  display: flex;
  align-items: flex-start;
}

.point-dot {
  width: 20rpx;
  height: 20rpx;
  border-radius: 50%;
  margin-right: 20rpx;
  margin-top: 8rpx;
  flex-shrink: 0;
}

.point-dot.start { background: #07c160; }
.point-dot.end { background: #f44336; }

.route-line {
  width: 2rpx;
  height: 40rpx;
  background: #ddd;
  margin-left: 10rpx;
  margin-top: 8rpx;
  margin-bottom: 8rpx;
}

.point-label {
  font-size: 24rpx;
  color: #999;
  display: block;
  margin-bottom: 8rpx;
}

.point-address {
  font-size: 28rpx;
  color: #333;
  display: block;
}

/* 信息卡片 */
.info-card {
  background: #fff;
  border-radius: 16rpx;
  padding: 24rpx;
}

.info-title {
  font-size: 30rpx;
  font-weight: 600;
  color: #333;
  margin-bottom: 24rpx;
}

.info-row {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 16rpx 0;
  border-bottom: 1rpx solid #f0f0f0;
}

.info-row:last-child {
  border-bottom: none;
}

.info-label {
  font-size: 28rpx;
  color: #666;
}

.info-value {
  font-size: 28rpx;
  color: #333;
}

.info-value.price {
  color: #f44336;
  font-size: 32rpx;
  font-weight: 600;
}

/* 用户信息 */
.user-info {
  display: flex;
  align-items: center;
}

.user-avatar {
  width: 80rpx;
  height: 80rpx;
  border-radius: 50%;
  margin-right: 20rpx;
}

.user-name {
  font-size: 30rpx;
  color: #333;
  font-weight: 500;
  display: block;
}

.user-phone {
  font-size: 26rpx;
  color: #07c160;
  margin-top: 8rpx;
  display: block;
}

/* 操作栏 */
.action-bar {
  position: fixed;
  left: 0;
  right: 0;
  bottom: 0;
  display: flex;
  align-items: center;
  padding: 20rpx 24rpx;
  background: #fff;
  box-shadow: 0 -4rpx 12rpx rgba(0, 0, 0, 0.05);
}

.action-group {
  display: flex;
  gap: 16rpx;
  width: 100%;
}

.action-btn {
  flex: 1;
  height: 88rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  border-radius: 44rpx;
  font-size: 30rpx;
  font-weight: 500;
  border: 1rpx solid #ddd;
  color: #666;
  background: #fff;
}

.action-btn.primary {
  background: #07c160;
  color: #fff;
  border-color: #07c160;
}

.action-btn.cancel {
  color: #f44336;
  border-color: #f44336;
}

.action-btn.full-width {
  flex: 1;
}
