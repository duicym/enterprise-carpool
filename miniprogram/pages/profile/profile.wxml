<!--pages/profile/profile.wxml-->
<view class="container">
  <!-- 用户信息卡片 -->
  <view class="user-card">
    <view class="user-info">
      <image class="avatar" src="{{userInfo.avatarUrl}}" mode="aspectFill"></image>
      <view class="user-detail">
        <view class="nickname">{{userInfo.nickname || '未知用户'}}</view>
        <view class="rating" wx:if="{{userStats}}">
          <text class="stars">{{ratingToStars(userStats.averageRating)}}</text>
          <text class="score">{{userStats.averageRating}}分</text>
        </view>
      </view>
    </view>

    <view class="credit-score" wx:if="{{userInfo.creditScore}}">
      <text class="score-value">{{userInfo.creditScore}}</text>
      <text class="score-label">信用分</text>
    </view>
  </view>

  <!-- 功能菜单 -->
  <view class="menu-list">
    <view class="menu-item" bindtap="goToMyCircles">
      <text class="menu-icon">👥</text>
      <text class="menu-text">我的圈子</text>
      <text class="menu-arrow">›</text>
    </view>

    <view class="menu-item" bindtap="goToMyTrips">
      <text class="menu-icon">🚗</text>
      <text class="menu-text">我的行程</text>
      <text class="menu-arrow">›</text>
    </view>

    <view class="menu-item" bindtap="goToMyReviews">
      <text class="menu-icon">⭐</text>
      <text class="menu-text">我的评价</text>
      <text class="menu-arrow">›</text>
    </view>
  </view>

  <!-- 设置 -->
  <view class="menu-list">
    <view class="menu-item">
      <text class="menu-icon">⚙️</text>
      <text class="menu-text">设置</text>
      <text class="menu-arrow">›</text>
    </view>

    <view class="menu-item" bindtap="onLogout">
      <text class="menu-icon">🚪</text>
      <text class="menu-text">退出登录</text>
      <text class="menu-arrow">›</text>
    </view>
  </view>

  <!-- 版本信息 -->
  <view class="version-info">
    <text>蹭蹭车 v1.0.0</text>
  </view>
</view>
