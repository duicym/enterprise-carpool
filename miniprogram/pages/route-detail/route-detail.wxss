.detail-page {
  min-height: 100vh;
  background: #f5f5f5;
  padding: 24rpx;
  padding-bottom: 160rpx;
}

.loading-wrap {
  display: flex;
  align-items: center;
  justify-content: center;
  height: 60vh;
  font-size: 28rpx;
  color: #999;
}

.detail-content {
  display: flex;
  flex-direction: column;
  gap: 24rpx;
}

/* 路线卡片 */
.route-card {
  background: #fff;
  border-radius: 16rpx;
  padding: 32rpx;
}

.route-points {
  position: relative;
}

.point {
  display: flex;
  align-items: flex-start;
}

.point-dot {
  width: 24rpx;
  height: 24rpx;
  border-radius: 50%;
  margin-right: 20rpx;
  margin-top: 8rpx;
  flex-shrink: 0;
}

.start-dot {
  background: #07c160;
}

.end-dot {
  background: #f44336;
}

.point-line {
  width: 2rpx;
  height: 40rpx;
  background: #ddd;
  margin-left: 12rpx;
  margin-top: 8rpx;
  margin-bottom: 8rpx;
}

.point-label {
  font-size: 24rpx;
  color: #999;
  display: block;
  margin-bottom: 8rpx;
}

.point-address {
  font-size: 30rpx;
  color: #333;
  display: block;
}

/* 车主卡片 */
.driver-card {
  background: #fff;
  border-radius: 16rpx;
  padding: 24rpx;
  display: flex;
  align-items: center;
  justify-content: space-between;
}

.driver-info {
  display: flex;
  align-items: center;
}

.driver-avatar {
  width: 80rpx;
  height: 80rpx;
  border-radius: 50%;
  margin-right: 20rpx;
}

.driver-name {
  font-size: 30rpx;
  color: #333;
  font-weight: 500;
}

.driver-rating {
  display: flex;
  align-items: center;
  margin-top: 8rpx;
}

.rating-star {
  font-size: 24rpx;
  color: #ffc107;
  margin-right: 2rpx;
}

.rating-text {
  font-size: 24rpx;
  color: #666;
  margin-left: 8rpx;
}

.company-tag {
  padding: 8rpx 20rpx;
  background: #e3f2fd;
  color: #1976d2;
  font-size: 24rpx;
  border-radius: 8rpx;
}

/* 行程信息 */
.trip-info-card {
  background: #fff;
  border-radius: 16rpx;
  padding: 24rpx;
}

.info-title {
  font-size: 30rpx;
  font-weight: 600;
  color: #333;
  margin-bottom: 24rpx;
}

.info-row {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 16rpx 0;
  border-bottom: 1rpx solid #f0f0f0;
}

.info-row:last-child {
  border-bottom: none;
}

.info-label {
  font-size: 28rpx;
  color: #666;
}

.info-value {
  font-size: 28rpx;
  color: #333;
  font-weight: 500;
}

.info-value.full {
  color: #f44336;
}

.info-value.available {
  color: #07c160;
}

.info-value.price {
  color: #f44336;
  font-size: 32rpx;
}

.info-value.remark {
  color: #666;
  font-weight: 400;
  font-size: 26rpx;
}

/* 操作栏 */
.action-bar {
  position: fixed;
  left: 0;
  right: 0;
  bottom: 0;
  display: flex;
  align-items: center;
  padding: 20rpx 24rpx;
  background: #fff;
  box-shadow: 0 -4rpx 12rpx rgba(0, 0, 0, 0.05);
}

.contact-btn {
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 0 32rpx;
}

.contact-icon {
  font-size: 40rpx;
  margin-bottom: 4rpx;
}

.contact-btn text:last-child {
  font-size: 24rpx;
  color: #666;
}

.book-btn {
  flex: 1;
  height: 88rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  background: #07c160;
  color: #fff;
  font-size: 32rpx;
  font-weight: 500;
  border-radius: 44rpx;
  margin-left: 24rpx;
}

.book-btn.disabled {
  background: #ccc;
}
