.review-page {
  min-height: 100vh;
  background: #f5f5f5;
  padding: 40rpx 24rpx 100rpx;
}

.page-header {
  text-align: center;
  margin-bottom: 40rpx;
}

.page-title {
  font-size: 40rpx;
  font-weight: 700;
  color: #333;
  display: block;
  margin-bottom: 12rpx;
}

.page-desc {
  font-size: 26rpx;
  color: #666;
}

/* 被评价人信息 */
.reviewee-card {
  background: #fff;
  border-radius: 16rpx;
  padding: 32rpx;
  display: flex;
  flex-direction: column;
  align-items: center;
  margin-bottom: 24rpx;
}

.reviewee-avatar {
  width: 120rpx;
  height: 120rpx;
  border-radius: 50%;
  margin-bottom: 16rpx;
}

.reviewee-name {
  font-size: 32rpx;
  color: #333;
  font-weight: 500;
}

/* 评分 */
.rating-section {
  background: #fff;
  border-radius: 16rpx;
  padding: 32rpx;
  display: flex;
  flex-direction: column;
  align-items: center;
  margin-bottom: 24rpx;
}

.section-title {
  font-size: 30rpx;
  color: #333;
  font-weight: 500;
  margin-bottom: 24rpx;
}

.stars {
  display: flex;
  align-items: center;
  gap: 16rpx;
}

.star-item {
  padding: 8rpx;
}

.star {
  font-size: 64rpx;
  color: #ddd;
}

.star.active {
  color: #ffc107;
}

.rating-text {
  margin-top: 16rpx;
  font-size: 28rpx;
  color: #666;
}

/* 评价内容 */
.content-section {
  background: #fff;
  border-radius: 16rpx;
  padding: 24rpx;
  margin-bottom: 24rpx;
}

.content-input {
  width: 100%;
  min-height: 200rpx;
  background: #f5f5f5;
  border-radius: 8rpx;
  padding: 20rpx;
  font-size: 28rpx;
  box-sizing: border-box;
}

.char-count {
  display: block;
  text-align: right;
  margin-top: 12rpx;
  font-size: 24rpx;
  color: #999;
}

/* 匿名选项 */
.anonymous-section {
  background: #fff;
  border-radius: 16rpx;
  padding: 24rpx;
  display: flex;
  align-items: center;
  justify-content: space-between;
  margin-bottom: 48rpx;
}

/* 提交按钮 */
.submit-btn {
  width: 100%;
  height: 96rpx;
  background: #07c160;
  color: #fff;
  font-size: 32rpx;
  font-weight: 500;
  border-radius: 48rpx;
}
