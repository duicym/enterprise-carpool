# 应用配置
NODE_ENV=development
APP_PORT=3000
APP_PREFIX=api

# 数据库配置
DB_HOST=localhost
DB_PORT=3306
DB_USERNAME=root
DB_PASSWORD=root
DB_DATABASE=carpool
DB_CHARSET=utf8mb4

# Redis 配置
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=
REDIS_DB=0

# 微信小程序配置
WECHAT_APP_ID=
WECHAT_APP_SECRET=
WECHAT_LOGIN_URL=https://api.weixin.qq.com/sns/jscode2session

# JWT 配置
JWT_SECRET=your-secret-key-change-in-production
JWT_EXPIRATION=7d
JWT_REFRESH_EXPIRATION=30d

# OSS 对象存储配置 (腾讯云 COS)
COS_BUCKET=
COS_REGION=ap-guangzhou
COS_SECRET_ID=
COS_SECRET_KEY=
COS_BASE_URL=https://carpool.example.com

# 日志配置
LOG_LEVEL=debug
LOG_FILE=/var/log/carpool-backend/app.log
